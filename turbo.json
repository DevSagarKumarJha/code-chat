{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["app/**", "src/**", "tsconfig.json"],
      "outputs": ["dist/**", "build/**"]
    }
  }
}
